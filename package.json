        "sass-loader": "^8.0.0",
        "vue-template-compiler": "^2.6.12"
    },
    "dependencies": {
        "bootstrap": "^4.5.2",
        "jquery": "^3.5.1",
        "popper.js": "^1.16.1",
        "slugify": "^1.4.5",
        "vue": "^2.6.11",
        "vue-i18n": "^8.21.0",
        "vue-moment": "^4.1.0",
        "vue-notification": "^1.3.20",
